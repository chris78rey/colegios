generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  templates Template[]
  requests  Request[]
  batches   Batch[]
  templateGroups TemplateGroup[]
  batchGroups BatchGroup[]
  credits   OrgCredit?

  @@index([status])
}

model User {
  id                  String   @id @default(cuid())
  organizationId      String?
  role                String
  email               String   @unique
  passwordHash        String
  mustChangePassword  Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model Template {
  id             String   @id @default(cuid())
  organizationId String
  name           String   @default("Plantilla")
  type           String
  pdfPath        String
  signX          Int
  signY          Int
  signPage       Int
  placeholders   Json?
  requiredColumns Json?
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  requests     Request[]
  batches      Batch[]
  groupItems   TemplateGroupItem[]

  @@index([organizationId])
}

model TemplateGroup {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  items        TemplateGroupItem[]
  batches      BatchGroup[]

  @@index([organizationId])
}

model TemplateGroupItem {
  id           String   @id @default(cuid())
  groupId      String
  templateId   String
  order        Int      @default(0)
  requiredSigners Int?
  createdAt    DateTime @default(now())

  group    TemplateGroup @relation(fields: [groupId], references: [id])
  template Template      @relation(fields: [templateId], references: [id])

  @@index([groupId])
  @@index([templateId])
}

model Request {
  id             String   @id @default(cuid())
  organizationId String
  templateId     String
  batchId        String?
  requestGroupId String?
  omniId         String?
  status         String   @default("PENDING")
  docxPath       String?
  pdfPath        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  template     Template     @relation(fields: [templateId], references: [id])
  batch        Batch?       @relation(fields: [batchId], references: [id])
  requestGroup RequestGroup? @relation(fields: [requestGroupId], references: [id])
  signatories  Signatory[]
  events       RequestEvent[]

  @@index([organizationId, status])
  @@index([templateId])
  @@index([omniId])
  @@index([requestGroupId])
}

model Batch {
  id             String   @id @default(cuid())
  organizationId String
  templateId     String
  status         String   @default("PENDING")
  totalCount     Int      @default(0)
  validCount     Int      @default(0)
  invalidCount   Int      @default(0)
  mapping        Json?
  docxZipPath    String?
  pdfZipPath     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  template     Template     @relation(fields: [templateId], references: [id])
  requests     Request[]

  @@index([organizationId, status])
  @@index([templateId])
}

model BatchGroup {
  id             String   @id @default(cuid())
  organizationId String
  groupId        String
  status         String   @default("PENDING")
  totalCount     Int      @default(0)
  validCount     Int      @default(0)
  invalidCount   Int      @default(0)
  mapping        Json?
  docxZipPath    String?
  pdfZipPath     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  group        TemplateGroup @relation(fields: [groupId], references: [id])
  requestGroups RequestGroup[]

  @@index([organizationId, status])
  @@index([groupId])
}

model RequestGroup {
  id           String   @id @default(cuid())
  batchGroupId String
  rowIndex     Int
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  batchGroup BatchGroup @relation(fields: [batchGroupId], references: [id])
  requests  Request[]

  @@index([batchGroupId])
  @@index([status])
}

model Signatory {
  id             String   @id @default(cuid())
  requestId      String
  idNumber       String
  fullName       String
  phone          String
  email          String
  sanitizedPhone String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  request Request @relation(fields: [requestId], references: [id])

  @@index([requestId])
  @@index([sanitizedPhone])
}

model RequestEvent {
  id        String   @id @default(cuid())
  requestId String
  status    String
  metaJson  Json?
  createdAt DateTime @default(now())

  request Request @relation(fields: [requestId], references: [id])

  @@index([requestId, createdAt])
}

model OrgCredit {
  organizationId String  @id
  balance        Int     @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}
