generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("active")
  billingModeDefault String @default("ORG_BALANCE")
  billingAmountDefault Decimal @default(0) @db.Decimal(10, 2)
  billingCurrency String @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  templates Template[]
  requests  Request[]
  batches   Batch[]
  templateGroups TemplateGroup[]
  batchGroups BatchGroup[]
  desktopBatches DesktopBatch[]
  omniRequests OmniRequest[]
  rcValidations RcValidation[]
  credits   OrgCredit?

  @@index([status])
}

model User {
  id                  String   @id @default(cuid())
  organizationId      String?
  role                String
  email               String   @unique
  passwordHash        String
  mustChangePassword  Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model Template {
  id             String   @id @default(cuid())
  organizationId String
  name           String   @default("Plantilla")
  type           String
  pdfPath        String
  signX          Int
  signY          Int
  signPage       Int
  placeholders   Json?
  requiredColumns Json?
  billingModeOverride String?
  billingAmountOverride Decimal? @db.Decimal(10, 2)
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  requests     Request[]
  batches      Batch[]
  groupItems   TemplateGroupItem[]

  @@index([organizationId])
}

model TemplateGroup {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  items        TemplateGroupItem[]
  batches      BatchGroup[]

  @@index([organizationId])
}

model TemplateGroupItem {
  id           String   @id @default(cuid())
  groupId      String
  templateId   String
  order        Int      @default(0)
  requiredSigners Int?
  createdAt    DateTime @default(now())

  group    TemplateGroup @relation(fields: [groupId], references: [id])
  template Template      @relation(fields: [templateId], references: [id])

  @@index([groupId])
  @@index([templateId])
}

model Request {
  id             String   @id @default(cuid())
  organizationId String
  templateId     String
  batchId        String?
  requestGroupId String?
  omniId         String?
  status         String   @default("PENDING")
  docxPath       String?
  pdfPath        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  template     Template     @relation(fields: [templateId], references: [id])
  batch        Batch?       @relation(fields: [batchId], references: [id])
  requestGroup RequestGroup? @relation(fields: [requestGroupId], references: [id])
  signatories  Signatory[]
  events       RequestEvent[]
  omniDocuments OmniDocument[]

  @@index([organizationId, status])
  @@index([templateId])
  @@index([omniId])
  @@index([requestGroupId])
}

model Batch {
  id             String   @id @default(cuid())
  organizationId String
  templateId     String
  status         String   @default("PENDING")
  totalCount     Int      @default(0)
  validCount     Int      @default(0)
  invalidCount   Int      @default(0)
  mapping        Json?
  docxZipPath    String?
  pdfZipPath     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  template     Template     @relation(fields: [templateId], references: [id])
  requests     Request[]

  @@index([organizationId, status])
  @@index([templateId])
}

model BatchGroup {
  id             String   @id @default(cuid())
  organizationId String
  groupId        String
  status         String   @default("PENDING")
  totalCount     Int      @default(0)
  validCount     Int      @default(0)
  invalidCount   Int      @default(0)
  mapping        Json?
  docxZipPath    String?
  pdfZipPath     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  group        TemplateGroup @relation(fields: [groupId], references: [id])
  requestGroups RequestGroup[]

  @@index([organizationId, status])
  @@index([groupId])
}

model RequestGroup {
  id           String   @id @default(cuid())
  batchGroupId String
  rowIndex     Int
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  batchGroup BatchGroup @relation(fields: [batchGroupId], references: [id])
  requests  Request[]
  omniRequests OmniRequest[]
  rcValidations RcValidation[]

  @@index([batchGroupId])
  @@index([status])
}

model Signatory {
  id             String   @id @default(cuid())
  requestId      String
  idNumber       String
  fullName       String
  phone          String
  email          String
  sanitizedPhone String
  role           String   @default("REPRESENTANTE_PRINCIPAL")
  isPrimary      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  request Request @relation(fields: [requestId], references: [id])

  @@index([requestId])
  @@index([sanitizedPhone])
}

model RequestEvent {
  id        String   @id @default(cuid())
  requestId String
  status    String
  metaJson  Json?
  createdAt DateTime @default(now())

  request Request @relation(fields: [requestId], references: [id])

  @@index([requestId, createdAt])
}

model OrgCredit {
  organizationId String  @id
  balance        Int     @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

model DesktopBatch {
  id             String   @id @default(cuid())
  organizationId String
  sourceExcel    String
  status         String   @default("IMPORTED")
  rowCount       Int      @default(0)
  documentCount  Int      @default(0)
  uploadedByEmail String?
  manifestJson   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  documents    DesktopDocument[]
  omniRequests OmniRequest[]
  rcValidations RcValidation[]

  @@index([organizationId, status])
}

model DesktopDocument {
  id           String   @id @default(cuid())
  batchId      String
  rowIndex     Int
  groupKey     String
  templateName String
  outputName   String
  status       String   @default("READY")
  pdfPath      String
  rowJson      Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  batch DesktopBatch @relation(fields: [batchId], references: [id])
  omniDocuments OmniDocument[]

  @@index([batchId, rowIndex])
  @@index([groupKey])
  @@index([status])
}

model OmniRequest {
  id                 String   @id @default(cuid())
  organizationId     String
  requestGroupId     String?
  desktopBatchId     String?
  provider           String   @default("OMNISWITCH")
  providerRequestId  String?
  status             String   @default("PENDING")
  billingMode        String   @default("ORG_BALANCE")
  billingAmount      Decimal  @default(0) @db.Decimal(10, 2)
  billingCurrency    String   @default("USD")
  paymentRequired    Boolean  @default(false)
  paymentReference   String?
  paymentStatus      String   @default("NOT_REQUIRED")
  idProcess          Int?
  documentCount      Int      @default(0)
  signatoryCount     Int      @default(0)
  sentAt             DateTime?
  signedAt           DateTime?
  lastPolledAt       DateTime?
  lastProviderStatus String?
  lastResultCode     Int?
  lastResultText     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  requestGroup RequestGroup? @relation(fields: [requestGroupId], references: [id])
  desktopBatch DesktopBatch? @relation(fields: [desktopBatchId], references: [id])
  documents    OmniDocument[]
  events       OmniEvent[]
  rcValidations RcValidation[]

  @@index([organizationId, status])
  @@index([providerRequestId])
  @@index([requestGroupId])
  @@index([desktopBatchId])
}

model OmniDocument {
  id                   String   @id @default(cuid())
  omniRequestId        String
  requestId            String?
  desktopDocumentId    String?
  providerDocumentName String
  localPdfPath         String?
  signedPdfPath        String?
  status               String   @default("PENDING")
  pageCount            Int?
  fileSizeBytes        Int?
  providerSignedFlag   String?
  downloadedAt         DateTime?
  lastResultCode       Int?
  lastResultText       String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  omniRequest     OmniRequest      @relation(fields: [omniRequestId], references: [id])
  request         Request?         @relation(fields: [requestId], references: [id])
  desktopDocument DesktopDocument? @relation(fields: [desktopDocumentId], references: [id])
  events          OmniEvent[]

  @@index([omniRequestId, status])
  @@index([requestId])
  @@index([desktopDocumentId])
  @@unique([omniRequestId, providerDocumentName])
}

model OmniEvent {
  id             String   @id @default(cuid())
  omniRequestId   String
  omniDocumentId  String?
  type           String
  message        String?
  metaJson       Json?
  createdAt      DateTime @default(now())

  omniRequest  OmniRequest   @relation(fields: [omniRequestId], references: [id])
  omniDocument OmniDocument? @relation(fields: [omniDocumentId], references: [id])

  @@index([omniRequestId, createdAt])
  @@index([omniDocumentId, createdAt])
}

model RcValidation {
  id                    String   @id @default(cuid())
  organizationId        String
  desktopBatchId        String?
  requestGroupId        String?
  omniRequestId         String?
  cedula                String
  fullName              String?
  phone                 String?
  email                 String?
  queryMode             String   @default("DEMOGRAPHIC")
  status                String   @default("PENDING")
  codigoDactilarProvided Boolean @default(false)
  providerRequestId     String?
  photoPath             String?
  signatureGraphPath    String?
  consentDocumentPath   String?
  consentFileName       String?
  lastResultCode        Int?
  lastResultText        String?
  validatedAt           DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  desktopBatch  DesktopBatch? @relation(fields: [desktopBatchId], references: [id])
  requestGroup  RequestGroup? @relation(fields: [requestGroupId], references: [id])
  omniRequest   OmniRequest? @relation(fields: [omniRequestId], references: [id])

  @@index([organizationId, status])
  @@index([desktopBatchId, status])
  @@index([requestGroupId, status])
  @@index([omniRequestId, status])
  @@index([cedula, createdAt])
}
